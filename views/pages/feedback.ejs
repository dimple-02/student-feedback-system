<%- include("../partials/head", { title, pageKey }) %>
<% const isAdminView = pageKey === "feedback-admin"; %>
<% if (isAdminView) { %>
<div class="app-shell">
  <%- include("../partials/navbar") %>
  <main class="app-content">
<% } %>
<section class="page">
  <header class="page-header">
    <div>
      <p class="eyebrow">Feedback</p>
      <h1><%= isAdminView ? "Review anonymous submissions" : "Share anonymous feedback" %></h1>
      <p class="muted"><%= isAdminView ? "Filter, export, and review student sentiment." : "Your name is never collected. Focus on the course or teacher." %></p>
    </div>
    <% if (!isAdminView && studentEmail) { %>
      <div class="student-profile" style="display: flex; align-items: center; gap: 12px;">
        <% if (studentProfilePic) { %>
          <img src="<%= studentProfilePic %>" alt="Profile" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover;" />
        <% } else { %>
          <div style="width: 48px; height: 48px; border-radius: 50%; background-color: #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 24px;">👤</div>
        <% } %>
        <div>
          <p style="font-size: 12px; color: #666; margin: 0;">Logged in as</p>
          <p style="font-size: 14px; font-weight: 500; margin: 0;"><%= studentEmail %></p>
        </div>
        <div style="margin-left: 8px; display:flex; align-items:center;">
          <button class="button ghost compact" id="studentLogoutButton" type="button" style="padding:6px 10px;">Logout</button>
        </div>
      </div>
    <% } %>
    <% if (isAdminView) { %>
      <div class="hero-stat">
        <p class="hero-label">Total entries</p>
        <p class="hero-value" id="feedbackTotalCount">0</p>
        
      </div>
    <% } %>
  </header>

  <% if (isAdminView) { %>
    <div class="action-row">
      <div class="filters">
        <label class="field compact wide">
          <span>Keyword</span>
          <input id="filterKeyword" placeholder="Search course, teacher, message" />
        </label>
        <label class="field compact">
          <span>Course or teacher</span>
          <select id="filterCourse"></select>
        </label>
        <label class="field compact">
          <span>Min rating</span>
          <select id="filterMinRating"></select>
        </label>
        <label class="field compact">
          <span>Max rating</span>
          <select id="filterMaxRating"></select>
        </label>
        <label class="field compact">
          <span>Start date</span>
          <input id="filterStartDate" type="date" />
        </label>
        <label class="field compact">
          <span>End date</span>
          <input id="filterEndDate" type="date" />
        </label>
      </div>
      <div class="actions">
        <button class="button secondary" type="button" id="exportCsvButton">Export CSV</button>
        <!-- <button class="button ghost" type="button" id="seedDataButton">Seed demo data</button> -->
        <button class="button ghost" type="button" id="clearFiltersButton">Clear filters</button>
        <button class="button danger" type="button" id="clearAllFeedbackButton">Clear all</button>
      </div>
    </div>
  <% } %>

  <div class="grid-2">
    <% if (!isAdminView) { %>
    <div>
      <% if (studentProfilePic || studentEmail) { %>
      <div class="card" style="margin-bottom: 16px; background: linear-gradient(135deg, #f5f5f5 0%, #fafafa 100%); border: 1px solid #e0e0e0;">
        <div style="padding: 20px; display: flex; align-items: center; gap: 16px;">
          <% if (studentProfilePic) { %>
            <img src="<%= studentProfilePic %>" alt="Profile" style="width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 3px solid #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />
          <% } else { %>
            <div style="width: 64px; height: 64px; border-radius: 50%; background-color: #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 32px; border: 3px solid #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">👤</div>
          <% } %>
          <div>
            <p style="font-size: 11px; color: #999; margin: 0; text-transform: uppercase; letter-spacing: 0.5px;">Student Account</p>
            <p style="font-size: 16px; font-weight: 600; margin: 4px 0 0 0; color: #333;"><%= studentEmail %></p>
          </div>
        </div>
        <!-- <div style="padding: 0 20px 20px 20px; border-top: 1px solid #ddd; margin-top: 12px; padding-top: 12px;">
          <label class="field compact">
            <span>Update Profile Picture</span>
            <input type="file" id="studentProfilePicInput" accept="image/*" />
          </label>
          <button class="button compact" id="studentUploadProfilePicBtn" style="margin-top: 8px; width: 100%;">Upload Photo</button>
          <p class="muted" id="studentUploadProfilePicMsg" style="margin-top: 8px; font-size: 12px;" hidden></p>
        </div> -->
      </div>
      <% } %>
    <form id="feedbackForm" class="card form">
      <div class="card-head">
        <h2 class="card-title">Submit anonymous feedback</h2>
        <span class="card-meta">Student form</span>
      </div>

      <label class="field">
        <span>Course or teacher</span>
        <input id="feedbackCourse" placeholder="Math 201 or Ms. Rivera" autocomplete="off" required />
      </label>

      <label class="field">
        <span>Feedback message</span>
        <textarea id="feedbackMessage" placeholder="Share what stood out and what could improve." rows="4" required></textarea>
      </label>

      <label class="field">
        <span>Rating</span>
        <select id="feedbackRating"></select>
      </label>

      <button class="button" type="submit">Submit feedback</button>
    </form>
    </div>
    <% } %>

    <% if (isAdminView) { %>
      <div class="card">
        <div class="card-head">
          <div>
            <h2 class="card-title">All feedback</h2>
            <p class="muted" id="feedbackShowingText">Showing 0 of 0 entries.</p>
          </div>
          <span class="card-meta">Admin view</span>
          <label class="field compact">
            <span>Sort</span>
            <select id="feedbackSort">
              <option value="recent">Most recent</option>
              <option value="rating">Highest rating</option>
            </select>
          </label>
        </div>
        <div class="feedback-list" id="feedbackList"></div>
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-head">
          <h2 class="card-title">What happens next</h2>
          <span class="card-meta">Student info</span>
        </div>
        <p class="muted">Submissions are anonymous. Admins review trends and feedback to improve course experiences.</p>
        <div class="actions">

          <!-- <a class="button secondary" href="/contact">Contact support</a> -->
        </div>
        <ul class="list">
          <li class="list-row">
            <span class="list-title">Anonymous by default</span>
            <span class="pill">No names saved</span>
          </li>
          <li class="list-row">
            <span class="list-title">Reviewed weekly</span>
            <span class="pill">Admin team</span>
          </li>
        </ul>
      </div>
    <% } %>
  </div>
  <div class="toast" id="toast" hidden></div>
</section>
<% if (isAdminView) { %>
  </main>
</div>
<% } %>
<%- include("../partials/scripts") %>
