<%- include("../partials/head", { title, pageKey }) %>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<section class="auth-shell">
  <form id="studentLoginForm" class="card auth-card">
    <div>
      <p class="eyebrow">Student access</p>
      <span class="card-meta">Secure</span>
      <h1>Log in to give feedback</h1>
      <p class="muted">You must use your chitkara.edu.in email address.</p>
    </div>

    <label class="field">
      <span>Email</span>
      <input id="studentLoginEmail" type="email" placeholder="student@chitkara.edu.in" required />
    </label>
    
    <label class="field">
      <span>Password</span>
      <input id="studentLoginPassword" type="password" placeholder="Enter your password" required />
    </label>

    <p class="error-text" id="studentLoginError" hidden></p>

    <button class="button" type="submit" style="margin-bottom: 0.5rem;">Log in</button>
    <div style="text-align: center; margin-bottom: 1rem;">
      <a href="/student/signup" class="muted" style="font-size: 0.875rem; text-decoration: underline;">Don't have an account? Register here</a>
    </div>
    
    <div style="display: flex; align-items: center; justify-content: center; margin: 1rem 0;">
      <span style="flex: 1; border-bottom: 1px solid var(--border-color);"></span>
      <span style="padding: 0 10px; color: var(--text-muted); font-size: 0.875rem;">OR</span>
      <span style="flex: 1; border-bottom: 1px solid var(--border-color);"></span>
    </div>

    <div id="googleSignInButton" style="display: flex; justify-content: center;"></div>
  </form>
</section>
<%- include("../partials/scripts") %>
